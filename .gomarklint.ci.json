{
  "default": true,
  "rules": {
    "final-blank-line": true,
    "unclosed-code-block": true,
    "empty-alt-text": true,
    "fenced-code-language": true,
    "heading-level": { "severity": "error", "minLevel": 1 },
    "duplicate-heading": true,
    "no-multiple-blank-lines": true,
    "no-setext-headings": true,
    "single-h1": true,
    "blanks-around-headings": true,
    "no-bare-urls": true,
    "no-empty-links": true,
    "no-emphasis-as-heading": true,
    "blanks-around-lists": true,
    "blanks-around-fences": true,
    "no-hard-tabs": true,
    "no-trailing-punctuation": { "punctuation": ".,;:!" },
    "consistent-code-fence": { "style": "consistent" },
    "consistent-emphasis-style": { "style": "consistent" },
    "consistent-list-marker": { "style": "consistent" },
    "max-line-length": { "enabled": false, "lineLength": 80 },
    "external-link": {
      "enabled": true,
      "severity": "error",
      "timeoutSeconds": 10,
      "maxConcurrency": 10,
      "maxRetries": 2,
      "retryDelayMs": 1000,
      "perHostConcurrency": 2,
      "perHostIntervalMs": 3000,
      "skipPatterns": []
    },
    "link-fragments": { "enabled": true, "slug-algorithm": "github" }
  },
  "include": ["ja/src", "en/src", "README.md", "CONTRIBUTING.md"],
  "ignore": ["ja/src/SUMMARY.md", "en/src/SUMMARY.md"],
  "output": "text"
}
